---
import '../styles/global.css';
const { title, description } = Astro.props;


const siteUrl = import.meta.env.PUBLIC_SITE_URL;
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
---

<html lang="es">
  <head>
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta name="description" content={description} />
    <meta charset="UTF-8" /> 
    <meta name="robots" content="index, follow">

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />

    <slot name="head" />
  </head>

  <body class="bg-gray-50 text-white antialiased min-h-screen flex flex-col" >
    <header class="bg-purple-600 shadow-md w-full">

      <div class="max-w-7xl mx-auto flex justify-between items-center p-4">
        <a href="/" class="font-bold text-xl">Inicio</a>
  
        <nav class="flex gap-4">
  
            <a href="/blog" class="hover:text-black">Blog</a>
            <a href="/about" class="hover:text-black">About</a>
            <a href="/contact" class="hover:text-black">Contacto</a>
        </nav>

      </div>
    </header>

    <main class="max-w-7xl mx-auto p-6 flex-grow text-gray-800">
      <slot />
    </main>

    <footer class="bg-black mt-10 p-4 text-center text-sm bg-">
      © 2026 SEOAPP
    </footer>

  </body>
</html>