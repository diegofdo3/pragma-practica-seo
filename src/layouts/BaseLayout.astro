---
import '../styles/global.css';
const { title, description } = Astro.props;


const siteUrl = import.meta.env.PUBLIC_SITE_URL;
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
---

<html lang="es">
  <head>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta charset="UTF-8" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />

    <slot name="head" />
  </head>

  <body class="bg-gray-50 text-gray-800 antialiased">
    <header class="bg-white shadow-md">
      <nav class="max-w-5xl mx-auto flex justify-between items-center p-4">
        <a href="/" class="font-bold text-xl">MiSitio</a>

        <div class="space-x-4">
          <a href="/blog" class="hover:text-blue-600">Blog</a>
          <a href="/about" class="hover:text-blue-600">About</a>
          <a href="/contact" class="hover:text-blue-600">Contacto</a>
        </div>
      </nav>
    </header>

    <main class="max-w-5xl mx-auto p-6">
      <slot />
    </main>

    <footer class="bg-gray-200 mt-10 p-4 text-center text-sm">
      © 2026 Mi Sitio SEO
    </footer>

  </body>
</html>