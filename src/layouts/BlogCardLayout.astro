---
const { cardTitle, cardRoute, cardDescription } = Astro.props;
---


<a href={ cardRoute }
    class="block p-6 bg-white rounded-xl shadow hover:shadow-lg transition">

  <h2 class="text-xl font-bold mb-2">
    { cardTitle }
  </h2>

  <p class="text-gray-600">
    { cardDescription }
  </p>

</a>