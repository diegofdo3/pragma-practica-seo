---
import BaseLayout from "../../layouts/BaseLayout.astro";
const title="Mi Producto"
const description="Producto optimizado para SEO"
---

<BaseLayout title={title} description={description}>

    <section class="grid md:grid-cols-2 gap-8 items-center">
  
      <img 
        src="/images/producto.webp"
        alt="Producto artesanal"
        class="rounded-xl shadow"
      />
  
      <div class="space-y-4">
  
        <h1 class="text-3xl font-bold">
          Mi Producto
        </h1>
  
        <p class="text-gray-600">
          Descripción del producto optimizada para SEO.
        </p>
  
        <p class="text-2xl font-semibold text-blue-600">
          $50.000
        </p>
  
        <a href="/contact"
           class="inline-block bg-blue-600 text-white px-5 py-2 rounded-lg hover:bg-blue-700 transition">
          Comprar ahora
        </a>
  
      </div>
  
    </section>
  
  </BaseLayout>