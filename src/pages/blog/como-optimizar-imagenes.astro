---
const title = "Guía de optimización de imágenes";
const description = "Mejora el SEO optimizando imágenes";

import BaseLayout from "../../layouts/BaseLayout.astro";

import SeoDiagram from '../../assets/images/seo_diagram.jpg'

const siteUrl = import.meta.env.PUBLIC_SITE_URL;
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "author": {
    "@type": "Person",
    "name": "Diego Hincapié"
  },
  "datePublished": "2026-04-14",
  "image": [`${siteUrl}${SeoDiagram.src}`],
  "url":canonicalUrl
}

---

<BaseLayout title={title} description={description}>
    <Fragment name="head">
        <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
    </Fragment>
    
    <article class="max-w-3xl mx-auto space-y-6">

        <nav class="text-sm text-gray-500">
          <a href="/" class="hover:underline">Home</a> >
          <a href="/blog" class="hover:underline">Blog</a> >
          Artículo
        </nav>
    
        <h1 class="text-3xl md:text-4xl font-bold">
          {title}
        </h1>
    
        <p class="text-gray-600">
          {description}
        </p>
    
        <img 
          src={SeoDiagram.src}
          alt="Optimización de imágenes para SEO"
          class="rounded-lg shadow"
        />
    
        <p class="text-gray-700 leading-relaxed">
          Aquí va tu contenido del artículo...
        </p>
    
        <h2 class="text-2xl font-semibold">
          ¿Por qué optimizar imágenes?
        </h2>
    
        <p class="text-gray-700 leading-relaxed">
          Explicación...
        </p>
    
      </article>

</BaseLayout>
