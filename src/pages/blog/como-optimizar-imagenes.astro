---
const title = "Guía de optimización de imágenes";
const description = "Mejora el SEO optimizando imágenes";

import BaseLayout from "../../layouts/BaseLayout.astro";

---

<BaseLayout title={title} description={description}>
    <Fragment name="head">
        <script type="application/ld+json">
            {
              "@context": "https://schema.org",
              "@type": "Article",
              "headline": "Cómo optimizar imágenes",
              "author": {
                "@type": "Person",
                "name": "Tu nombre"
              },
              "datePublished": "2026-04-14",
              "image": ["/images/seo.webp"]
            }
        </script>
    </Fragment>
    
    <article class="max-w-3xl mx-auto space-y-6">

        <!-- Breadcrumb -->
        <nav class="text-sm text-gray-500">
          <a href="/" class="hover:underline">Home</a> >
          <a href="/blog" class="hover:underline">Blog</a> >
          Artículo
        </nav>
    
        <h1 class="text-3xl md:text-4xl font-bold">
          {title}
        </h1>
    
        <p class="text-gray-600">
          {description}
        </p>
    
        <img 
          src="/images/seo.webp"
          alt="Optimización de imágenes para SEO"
          class="rounded-lg shadow"
        />
    
        <p class="text-gray-700 leading-relaxed">
          Aquí va tu contenido del artículo...
        </p>
    
        <h2 class="text-2xl font-semibold">
          ¿Por qué optimizar imágenes?
        </h2>
    
        <p class="text-gray-700 leading-relaxed">
          Explicación...
        </p>
    
      </article>

</BaseLayout>
