---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="Blog" description="Artículos sobre SEO y desarrollo web">

    <section class="space-y-6">
  
      <h1 class="text-4xl font-bold">
        Blog
      </h1>
  
      <div class="grid md:grid-cols-2 gap-6">
  
        <a href="/blog/como-optimizar-imagenes"
           class="block p-6 bg-white rounded-xl shadow hover:shadow-lg transition">
  
          <h2 class="text-xl font-bold mb-2">
            Cómo optimizar imágenes
          </h2>
  
          <p class="text-gray-600">
            Mejora el SEO optimizando imágenes correctamente.
          </p>
  
        </a>
  
      </div>
  
    </section>
  
  </BaseLayout>
