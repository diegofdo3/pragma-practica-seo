---
import BaseLayout from '../layouts/BaseLayout.astro';
const title="Inicio"
const description="Página principal"
---

<BaseLayout title={ title } description={ description }>

  <h1 class="text-4xl font-bold mb-6">
    Bienvenido a Mi Sitio SEO
  </h1>

  <section>
    <h2 class="text-2xl font-semibold mb-4">
      Últimos artículos
    </h2>

    <div class="grid gap-4">

      <a href="/blog/como-optimizar-imagenes"
         class="block p-4 bg-white rounded-xl shadow hover:shadow-lg transition">

        <h3 class="text-xl font-bold">
          Cómo optimizar imágenes
        </h3>

        <p class="text-gray-600">
          Mejora tu SEO optimizando imágenes
        </p>

      </a>

    </div>
  </section>

</BaseLayout>